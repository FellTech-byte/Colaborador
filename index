                    <div class="mt-2 text-right"><label class="text-[9px] font-bold text-gray-400 uppercase flex items-center justify-end gap-1">N/A <input type="checkbox" ${status === 'na' ? 'checked' : ''} onchange="toggleNA('${emp.id}','${t.id}', this.checked)"></label></div>`;
