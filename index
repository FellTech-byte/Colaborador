        window.uploadFile = async (input, empId, docId) => {
            const file = input.files[0]; if(!file) return; toggleLoading(true);
            try {
                const path = `docs/${empId}/${docId}_${Date.now()}`; const sRef = ref(storage, path); const snapshot = await uploadBytes(sRef, file); const url = await getDownloadURL(snapshot.ref);
                const empRef = doc(db, "funcionarios", empId); const updateData = {}; updateData[`documentos.${docId}`] = { url: url, status: 'analise', uploadedAt: new Date().toISOString(), uploadedBy: currentUser.email };
                await updateDoc(empRef, updateData); openDocs(empId);
            } catch (e) { console.error(e); alert("Erro ao enviar arquivo."); } finally { toggleLoading(false); }
