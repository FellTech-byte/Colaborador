        const updateUIForUser = () => {
            document.getElementById('view-auth').classList.add('hidden');
            document.getElementById('app-header').classList.remove('hidden');
            document.getElementById('app-container').classList.remove('hidden');
            document.getElementById('user-email').innerText = currentUser.email;
            document.getElementById('user-role').innerText = isAdmin ? "Administrador" : "Operador";
            if(isAdmin) document.getElementById('admin-menu').classList.remove('hidden');
        };

        async function loadProjects() {
            toggleLoading(true);
            try {
                const projCol = collection(db, 'projetos');
                let q;
                if (isAdmin) { q = query(projCol); } 
                else {
                    const allowedIds = currentUserData.projetosPermitidos || [];
                    if (allowedIds.length > 0) { q = query(projCol, where('__name__', 'in', allowedIds)); } 
                    else { q = null; }
                }
                
                if (q) {
                    const snap = await getDocs(q);
                    projects = snap.docs.map(d => ({ id: d.id, ...d.data() }));
                } else { projects = []; }
            } catch (e) {
                console.error("Erro ao carregar projetos:", e);
                projects = []; 
            } finally {
                renderProjectSelector();
                const sel = document.getElementById('header-project-select');
                
                if (!currentProject) {
                    if (sel.options.length > 0 && sel.value) {
                         if(sel.value !== 'orphan' && sel.value !== 'legacy_av_metro') changeProject(sel.value);
                    } else if (isAdmin) {
                         changeProject('legacy_av_metro');
                    } else {
                        initApp();
                    }
                }
                toggleLoading(false);
            }
        }

        function renderProjectSelector() {
            const sel = document.getElementById('header-project-select');
            sel.innerHTML = '';
            
            if (isAdmin) {
                const optOrphan = document.createElement('option');
                optOrphan.value = 'orphan'; optOrphan.text = '⚠️ Colaboradores Sem Projeto';
                sel.appendChild(optOrphan);
                const optLegacyAvMetro = document.createElement('option');
                optLegacyAvMetro.value = 'legacy_av_metro'; optLegacyAvMetro.text = 'Avenida do Metrô (Legado)';
                sel.appendChild(optLegacyAvMetro);
            }

            if (projects.length === 0 && !isAdmin) {
                const emptyOpt = document.createElement('option');
                emptyOpt.text = "Sem projetos disponíveis"; sel.appendChild(emptyOpt); sel.disabled = true; return;
            }
            sel.disabled = false;
            
            projects.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.id; opt.text = p.nome;
                sel.appendChild(opt);
            });
            
            sel.onchange = (e) => changeProject(e.target.value);
        }

        async function changeProject(projId) {
            if (!projId) {
                currentProject = null;
                initApp(); 
                return;
            }

            if (projId === 'orphan') currentProject = { id: 'orphan', nome: 'Colaboradores Sem Projeto' };
            else if (projId === 'legacy_av_metro') currentProject = { id: 'legacy_av_metro', nome: 'Avenida do Metrô (Legado)' };
            else currentProject = projects.find(p => p.id === projId);
            
            if (currentProject) {
                const sel = document.getElementById('header-project-select');
                if (sel) sel.value = projId;
                initApp();
            }
        }
        
        // Expor para o escopo global para funcionar no onclick
        window.changeProject = changeProject;

        const initApp = () => {
            const dash = document.getElementById('dashboard-content');
            const placeholder = document.getElementById('no-project-selected');
            const noAccess = document.getElementById('no-access-state');
            
            if(employeesUnsubscribe) employeesUnsubscribe();

            if (!isAdmin && projects.length === 0) {
                dash.classList.add('hidden');
                placeholder.classList.add('hidden');
                noAccess.classList.remove('hidden');
                document.getElementById('dashboard-title').innerText = "Acesso Restrito";
                return;
            }

            if (!currentProject) {
                dash.classList.add('hidden');
                noAccess.classList.add('hidden');
                placeholder.classList.remove('hidden');
                return;
            }
            
            dash.classList.remove('hidden');
            noAccess.classList.add('hidden');
            placeholder.classList.add('hidden');
            document.getElementById('dashboard-title').innerText = currentProject.nome;

            let q;
            if (currentProject.id === 'orphan') q = query(collection(db, "funcionarios"));
            else if (currentProject.id === 'legacy_av_metro') q = query(collection(db, "funcionarios"), where("projetoId", "==", "Avenida do Metrô"));
            else q = query(collection(db, "funcionarios"), where("projetoId", "==", currentProject.id));

            employeesUnsubscribe = onSnapshot(q, (s) => {
                const allDocs = s.docs.map(d => ({id: d.id, ...d.data()}));
                if (currentProject.id === 'orphan') employees = allDocs.filter(e => !e.projetoId || e.projetoId === "");
                else employees = allDocs;
                renderDashboard();
            });
        };

        window.changeView = (v) => {
            ['dashboard', 'form', 'docs', 'projects', 'users'].forEach(n => document.getElementById(`view-${n}`).classList.add('hidden'));
            document.getElementById(`view-${v}`).classList.remove('hidden');
            document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
            if(v==='dashboard') renderDashboard();
            if(v==='form') { 
                if(!document.getElementById('emp-id').value) resetForm(); 
            }
            if(v==='projects') renderProjectsView();
            if(v==='users') renderUsersView();
            lucide.createIcons();
        };

        const renderDashboard = () => {
            const tb = document.getElementById('table-body'); tb.innerHTML = '';
            let pen = 0, apr = 0;
            employees.forEach(e => {
                const docs = e.documentos || {};
                const list = getDocsList(e);
                let completedCount = 0;
                let hasRej = false, hasAna = false;
                
                list.forEach(t => {
                    const d = docs[t.id];
                    const status = d ? d.status : null;
                    if(status === 'aprovado' || status === 'analise' || status === 'na') { completedCount++; }
                    if(status === 'reprovado') hasRej = true;
                    if(status === 'analise') hasAna = true;
                });

                let statusHtml = '<span class="status-badge status-pendente">Incompleto</span>';
                
                if(hasRej) { statusHtml = '<span class="status-badge status-reprovado">Pendência</span>'; pen++; }
                else if(completedCount === list.length) {
                    if(hasAna) { statusHtml = '<span class="status-badge status-analise">Em Análise</span>'; pen++; } else { statusHtml = '<span class="status-badge status-conforme">Aprovado</span>'; apr++; }
                } 
                else { pen++; }

                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 border-b";
                tr.innerHTML = `
                    <td class="px-6 py-4 font-bold">${e.nome}</td>
                    <td class="px-6 py-4">${e.funcao}</td>
                    <td class="px-6 py-4 text-center"><span class="bg-gray-100 px-2 py-1 rounded text-xs font-bold">${completedCount}/${list.length}</span></td>
                    <td class="px-6 py-4 text-center">${statusHtml}</td>
                    <td class="px-6 py-4 text-right flex justify-end gap-2">
                        <button onclick="editEmployee('${e.id}')" class="p-2 text-orange-600 bg-orange-50 rounded"><i data-lucide="pencil" class="w-4 h-4"></i></button>
                        <button onclick="openDocs('${e.id}')" class="p-2 text-blue-600 bg-blue-50 rounded"><i data-lucide="folder-search" class="w-4 h-4"></i></button>
                        ${isAdmin ? `<button onclick="deleteEmployee('${e.id}')" class="p-2 text-red-600 bg-red-50 rounded"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : ''}
                    </td>
                `;
                tb.appendChild(tr);
            });
            document.getElementById('kpi-total').innerText = employees.length;
            document.getElementById('kpi-pending').innerText = pen;
            document.getElementById('kpi-approved').innerText = apr;
            lucide.createIcons();
        };

        // --- FUNÇÕES DE ADMINISTRAÇÃO RESTAURADAS ---
        
