            const uid = document.getElementById('user-edit-id').value;
            const checkboxes = document.querySelectorAll('.proj-checkbox:checked');
            const newAllowed = Array.from(checkboxes).map(cb => cb.value);
            
            toggleLoading(true);
            try {
                await updateDoc(doc(db, 'usuarios', uid), { projetosPermitidos: newAllowed });
                document.getElementById('user-edit-modal').classList.remove('active');
                renderUsersView();
                customAlert("Permissões atualizadas com sucesso!");
            } catch(e) {
                console.error(e);
                customAlert("Erro ao salvar permissões.");
            } finally {
                toggleLoading(false);
            }
        };

