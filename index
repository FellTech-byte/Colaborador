        window.newEmployee = () => { resetForm(); changeView('form'); };
        function resetForm() {
            document.getElementById('emp-id').value = ''; document.getElementById('employee-form').reset(); const sel = document.getElementById('input-projeto-form'); sel.innerHTML = '<option value="">Selecione um projeto...</option>'; if(isAdmin) { const optAv = document.createElement('option'); optAv.value = "Avenida do Metrô"; optAv.text = "Avenida do Metrô (Legado)"; sel.appendChild(optAv); } projects.forEach(p => { const opt = document.createElement('option'); opt.value = p.id; opt.text = p.nome; sel.appendChild(opt); }); if(projects.length === 1) { sel.selectedIndex = 1; } else if(currentProject && currentProject.id !== 'orphan' && currentProject.id !== 'legacy_av_metro') { sel.value = currentProject.id; }
        }

        window.editEmployee = (id) => {
            const e = employees.find(x => x.id === id); document.getElementById('emp-id').value = e.id; document.getElementById('input-nome').value = e.nome; document.getElementById('input-funcao').value = e.funcao; document.getElementById('input-empresa').value = e.empresa; document.getElementById('input-cpf').value = e.cpf; document.getElementById('input-is-rpa').checked = e.isDriverRPA || false; resetForm(); const sel = document.getElementById('input-projeto-form'); if(e.projetoId) { if(e.projetoId === "Avenida do Metrô") sel.value = "Avenida do Metrô"; else sel.value = e.projetoId; } changeView('form');
        };

        document.getElementById('employee-form').addEventListener('submit', async (e) => {
            e.preventDefault(); toggleLoading(true); const id = document.getElementById('emp-id').value; const data = { nome: document.getElementById('input-nome').value, funcao: document.getElementById('input-funcao').value, empresa: document.getElementById('input-empresa').value, cpf: document.getElementById('input-cpf').value, isDriverRPA: document.getElementById('input-is-rpa').checked, projetoId: document.getElementById('input-projeto-form').value, updatedAt: new Date().toISOString() };
            try { if (id) await updateDoc(doc(db, "funcionarios", id), data); else { data.documentos = {}; await addDoc(collection(db, "funcionarios"), data); } changeView('dashboard'); } finally { toggleLoading(false); }
        });

        document.getElementById('auth-form').addEventListener('submit', async (e) => {
            e.preventDefault(); const email = document.getElementById('auth-email').value; const pass = document.getElementById('auth-password').value; toggleLoading(true); try { if(isRegisterMode) { await createUserWithEmailAndPassword(auth, email, pass); await addDoc(collection(db, "usuarios"), { email: email, isAdmin: false, projetosPermitidos: [] }); } else { await signInWithEmailAndPassword(auth, email, pass); } } catch (err) { document.getElementById('auth-error').innerText = "Erro na autenticação. Verifique os dados."; document.getElementById('auth-error').classList.remove('hidden'); } finally { toggleLoading(false); }
        });

        let isRegisterMode = false;
        document.getElementById('btn-toggle-register').onclick = () => { isRegisterMode = !isRegisterMode; document.querySelector('#view-auth h1').innerText = isRegisterMode ? "Criar Conta" : "Acesso ao Sistema"; document.getElementById('btn-toggle-register').innerText = isRegisterMode ? "Já tem conta? Login" : "Criar nova conta"; };
        document.getElementById('btn-logout').onclick = () => signOut(auth);
        window.openProjectModal = () => document.getElementById('project-modal').classList.add('active');
        window.closeProjectModal = () => document.getElementById('project-modal').classList.remove('active');
        document.getElementById('project-form').onsubmit = async (e) => { e.preventDefault(); const nome = document.getElementById('proj-name').value; await addDoc(collection(db, 'projetos'), { nome, createdAt: new Date().toISOString() }); closeProjectModal(); await loadProjects(); renderProjectsView(); };
    </script>
</body>
</html>
