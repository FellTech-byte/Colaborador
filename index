                        <label class="w-full py-1.5 text-xs font-bold border-2 border-dashed rounded bg-gray-50 hover:bg-white cursor-pointer flex items-center justify-center gap-1"><i data-lucide="upload-cloud" class="w-3 h-3"></i> ${d && d.url ? 'Substituir' : 'Enviar'}<input type="file" class="hidden" onchange="uploadFile(this, '${emp.id}', '${t.id}')"></label>
