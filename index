        // --- HELPERS DE MODAL ---
        const showModal = (t, c, a) => { document.getElementById('modal-title').innerText=t; document.getElementById('modal-content').innerHTML=c; document.getElementById('modal-actions').innerHTML=a; document.getElementById('modal-overlay').classList.add('active'); };
