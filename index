        window.editUserPermissions = async (uid, email) => {
            document.getElementById('user-edit-id').value = uid;
            document.getElementById('user-edit-email').innerText = email;
            const list = document.getElementById('user-projects-list');
            list.innerHTML = 'Carregando...';
            document.getElementById('user-edit-modal').classList.add('active');
            
            try {
                const userDoc = await getDoc(doc(db, 'usuarios', uid));
                const userData = userDoc.data();
                const allowed = userData.projetosPermitidos || [];
                
                list.innerHTML = '';
                if(projects.length === 0) {
                    list.innerHTML = '<p class="text-xs text-gray-400 italic">Nenhum projeto cadastrado.</p>';
                    return;
                }
                
                projects.forEach(p => {
                    const isChecked = allowed.includes(p.id) ? 'checked' : '';
                    const div = document.createElement('div');
                    div.className = "flex items-center gap-2 p-1 hover:bg-gray-50 rounded";
                    div.innerHTML = `<input type="checkbox" class="proj-checkbox w-4 h-4 text-brand-dark rounded" value="${p.id}" ${isChecked}><span class="text-sm text-gray-700">${p.nome}</span>`;
