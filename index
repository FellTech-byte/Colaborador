<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Colaboradores</title>
    <!-- Favicon com o ícone do sistema -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%239FC419%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><path d=%22M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2%22/><circle cx=%229%22 cy=%227%22 r=%224%22/><path d=%22M22 21v-2a4 4 0 0 0-3-3.87%22/><path d=%22M16 3.13a4 4 0 0 1 0 7.75%22/></svg>">
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body { font-family: 'Lato', sans-serif; background-color: #f3f4f6; }
        
        .bg-brand-dark { background-color: #003B4D; }
        .text-brand-lime { color: #A3C639; }
        .bg-brand-lime { background-color: #A3C639; }
        .hover-bg-brand-lime:hover { background-color: #8da630; }

        .nav-link { display: flex; align-items: center; gap: 0.75rem; width: 100%; text-align: left; padding: 0.75rem 1rem; border-radius: 0.375rem; transition: all 0.2s; font-weight: 500; color: #374151; font-size: 0.9rem; }
        .nav-link:hover { background-color: #e5e7eb; }
        .nav-link.active { background-color: #003B4D; color: white; font-weight: 700; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }

        .card-doc { transition: all 0.3s ease; border-width: 2px; position: relative; }
        .card-pendente { border-color: #e5e7eb; background-color: #ffffff; }
        .card-analise { border-color: #3b82f6; background-color: #eff6ff; }
        .card-aprovado { border-color: #22c55e; background-color: #f0fdf4; }
        .card-reprovado { border-color: #ef4444; background-color: #fef2f2; }
        .card-na { border-color: #9ca3af; background-color: #f3f4f6; opacity: 0.8; }

        .status-badge { padding: 0.25rem 0.75rem; border-radius: 9999px; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; display: inline-flex; align-items: center; gap: 0.3rem; }
        .status-conforme { background-color: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .status-reprovado { background-color: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }
        .status-pendente { background-color: #fef9c3; color: #854d0e; border: 1px solid #fde047; }
        .status-analise { background-color: #dbeafe; color: #1e40af; border: 1px solid #bfdbfe; }

        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        
        #loading-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; justify-content: center; align-items: center; z-index: 50; visibility: hidden; opacity: 0; transition: 0.3s; backdrop-filter: blur(2px); }
        #loading-overlay.visible { visibility: visible; opacity: 1; }
        
        .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 60; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
        .modal-overlay.active { display: flex; opacity: 1; }
        .modal-box { background: white; border-radius: 0.5rem; padding: 1.5rem; width: 90%; max-width: 600px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); transform: scale(0.95); transition: transform 0.2s; }
        .modal-overlay.active .modal-box { transform: scale(1); }
        
        #gallery-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 100; display: none; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; }
        #gallery-overlay.active { display: flex; opacity: 1; }
        #gallery-content { width: 90%; height: 85%; display: flex; align-items: center; justify-content: center; position: relative; }
        
        .rpa-switch { position: relative; display: inline-block; width: 50px; height: 28px; }
        .rpa-switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 20px; width: 20px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: #003B4D; }
        input:checked + .slider:before { transform: translateX(22px); }

        .timeline-item { position: relative; padding-left: 1.5rem; border-left: 2px solid #e5e7eb; padding-bottom: 1rem; }
        .timeline-dot { position: absolute; left: -5px; top: 0; width: 10px; height: 10px; border-radius: 50%; background-color: #003B4D; }
    </style>
</head>
<body class="text-gray-800 h-screen flex flex-col overflow-hidden">

    <!-- LOGIN -->
    <div id="view-auth" class="fixed inset-0 bg-brand-dark z-[100] flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl p-10 w-full max-w-sm fade-in">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-blue-50 text-brand-dark mb-4 shadow-sm border border-blue-100">
                    <i data-lucide="shield-check" class="w-10 h-10"></i>
                </div>
                <h1 class="text-2xl font-black text-gray-800">Acesso ao Sistema</h1>
            </div>
            <form id="auth-form" class="space-y-5">
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">E-mail</label>
                    <input type="email" id="auth-email" required class="w-full border border-gray-200 bg-[#eff4ff] p-3 rounded-lg outline-none text-sm font-bold">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Senha</label>
                    <input type="password" id="auth-password" required class="w-full border border-gray-200 bg-[#eff4ff] p-3 rounded-lg outline-none text-sm font-bold">
                </div>
                <div id="auth-error" class="hidden text-red-500 text-xs font-bold text-center bg-red-50 p-2 rounded"></div>
                <button type="submit" class="w-full bg-brand-lime hover:hover-bg-brand-lime text-white py-3 rounded-lg font-bold shadow-lg transition uppercase tracking-wide">Entrar</button>
            </form>
            <div class="mt-8 text-center pt-6 border-t border-gray-100">
                <button id="btn-toggle-register" class="text-xs text-brand-dark hover:underline font-bold">Não tem conta? Cadastre-se</button>
            </div>
        </div>
    </div>

    <!-- HEADER -->
    <header class="bg-brand-dark text-white shadow-lg z-20 h-16 flex-none hidden" id="app-header">
        <div class="w-full h-full flex justify-between items-center px-4 md:px-8">
            <div class="flex items-center gap-4">
                <i data-lucide="users" class="text-brand-lime w-7 h-7"></i>
                <h1 class="text-xl font-bold tracking-tight hidden md:block">Gestão de Colaboradores</h1>
            </div>

            <div class="flex-1 max-w-sm mx-4">
                <div class="relative">
                    <select id="header-project-select" class="w-full pl-4 pr-8 py-1.5 rounded text-sm text-gray-700 font-bold focus:outline-none bg-white appearance-none">
                        <option value="">Carregando...</option>
                    </select>
                </div>
            </div>

            <div class="flex items-center gap-4">
                <div class="hidden md:flex flex-col items-end">
                    <p id="user-email" class="text-xs font-bold"></p>
                    <p id="user-role" class="text-[10px] font-black text-brand-lime uppercase tracking-widest"></p>
                </div>
                <button id="btn-logout" class="p-2 bg-white/10 hover:bg-white/20 rounded-lg transition">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                </button>
            </div>
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden hidden" id="app-container">
        <!-- SIDEBAR -->
        <nav class="w-64 bg-white border-r border-gray-200 flex-none flex flex-col pt-6 pb-4">
            <div class="px-4 space-y-2">
                <button class="nav-link active" onclick="changeView('dashboard')"><i data-lucide="layout-dashboard" class="w-5 h-5"></i> Dashboard</button>
                <button class="nav-link" onclick="newEmployee()"><i data-lucide="user-plus" class="w-5 h-5"></i> Novo Colaborador</button>
                
                <div id="admin-menu" class="hidden pt-4 border-t border-gray-100 mt-4">
                    <button class="nav-link" onclick="changeView('projects')"><i data-lucide="building" class="w-5 h-5"></i> Meus Projetos</button>
                    <button class="nav-link" onclick="changeView('users')"><i data-lucide="users-round" class="w-5 h-5"></i> Acessos</button>
                </div>
            </div>
            <div class="mt-auto px-4 text-center">
                <p class="text-[10px] text-gray-400 font-bold">Versão 1.5.0</p>
            </div>
        </nav>

        <!-- MAIN -->
        <main class="flex-1 overflow-y-auto p-4 md:p-8 bg-gray-50">
            
            <!-- VIEW: DASHBOARD -->
            <div id="view-dashboard" class="fade-in max-w-7xl mx-auto">
                <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800" id="dashboard-title">Painel do Projeto</h2>
                        <p class="text-gray-500 text-sm" id="dashboard-subtitle">Selecione um projeto para começar.</p>
                    </div>
                    <button onclick="newEmployee()" class="bg-brand-dark text-white px-5 py-2.5 rounded-lg font-bold shadow-md flex items-center gap-2">
                        <i data-lucide="plus-circle" class="w-5 h-5"></i> Novo Cadastro
                    </button>
                </div>

                <div id="dashboard-content" class="hidden">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                        <div class="bg-white p-5 rounded-xl border flex items-center justify-between">
                            <div><p class="text-gray-500 text-xs font-bold uppercase">Total</p><p id="kpi-total" class="text-3xl font-black">0</p></div>
                            <div class="p-3 bg-blue-50 rounded-full text-blue-600"><i data-lucide="users" class="w-6 h-6"></i></div>
                        </div>
                        <div class="bg-white p-5 rounded-xl border flex items-center justify-between">
                            <div><p class="text-gray-500 text-xs font-bold uppercase">Pendentes</p><p id="kpi-pending" class="text-3xl font-black text-yellow-600">0</p></div>
                            <div class="p-3 bg-yellow-50 rounded-full text-yellow-600"><i data-lucide="clock" class="w-6 h-6"></i></div>
                        </div>
                        <div class="bg-white p-5 rounded-xl border flex items-center justify-between">
                            <div><p class="text-gray-500 text-xs font-bold uppercase">Aprovados</p><p id="kpi-approved" class="text-3xl font-black text-green-600">0</p></div>
                            <div class="p-3 bg-green-50 rounded-full text-green-600"><i data-lucide="check-circle-2" class="w-6 h-6"></i></div>
                        </div>
                    </div>
                    <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                        <table class="w-full text-left">
                            <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-bold">
                                <tr>
                                    <th class="px-6 py-4">Colaborador</th>
                                    <th class="px-6 py-4">Função</th>
                                    <th class="px-6 py-4 text-center">Docs</th>
                                    <th class="px-6 py-4 text-center">Status</th>
                                    <th class="px-6 py-4 text-right">Ações</th>
                                </tr>
                            </thead>
                            <tbody id="table-body" class="divide-y text-sm"></tbody>
                        </table>
                    </div>
                </div>
                <div id="no-project-selected" class="p-10 text-center bg-white rounded-xl border border-dashed">
                    <p class="text-gray-500">Utilize o seletor no topo para carregar os dados.</p>
                </div>
                
                <!-- ESTADO VAZIO PARA COLABORADOR SEM PERMISSÃO -->
                <div id="no-access-state" class="hidden p-10 text-center bg-red-50 rounded-xl shadow-sm border border-red-200">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-100 mb-4 text-red-500"><i data-lucide="lock" class="w-8 h-8"></i></div>
                    <h3 class="text-lg font-bold text-red-800">Sem Projetos Disponíveis</h3>
                    <p class="text-gray-600 mt-2">Você ainda não possui acesso a nenhum projeto.</p>
                    <p class="text-gray-500 text-sm">Solicite ao administrador para liberar seu acesso.</p>
                </div>
            </div>

            <!-- VIEW: FORM -->
            <div id="view-form" class="hidden fade-in max-w-3xl mx-auto">
                <div class="bg-white rounded-xl shadow-lg border overflow-hidden">
                    <div class="bg-gray-50 px-8 py-6 border-b flex justify-between items-center">
                        <h2 id="form-title" class="text-xl font-bold text-brand-dark">Novo Colaborador</h2>
                    </div>
                    <form id="employee-form" class="p-8 space-y-6">
                        <input type="hidden" id="emp-id">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Projeto Destino *</label>
                            <select id="input-projeto-form" required class="w-full border rounded-lg p-2.5 text-sm outline-none"></select>
                        </div>
                        <div class="p-4 bg-orange-50 border border-orange-200 rounded-lg flex items-center justify-between">
                            <div><h3 class="font-bold text-sm">Tipo de Contratação</h3><p class="text-xs text-gray-500">Ative se for Motorista RPA/PJ</p></div>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <span class="text-xs font-bold">Padrão</span>
                                <div class="rpa-switch"><input type="checkbox" id="input-is-rpa"><span class="slider"></span></div>
                                <span class="text-xs font-bold">Motorista RPA</span>
                            </label>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="col-span-2"><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Nome Completo *</label><input type="text" id="input-nome" required class="w-full border rounded-lg p-2.5 outline-none"></div>
                            <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Função *</label><input type="text" id="input-funcao" required class="w-full border rounded-lg p-2.5 outline-none"></div>
                            <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">Empresa *</label><input type="text" id="input-empresa" required class="w-full border rounded-lg p-2.5 outline-none"></div>
                            <div><label class="block text-xs font-bold text-gray-500 uppercase mb-1">CPF *</label><input type="text" id="input-cpf" required class="w-full border rounded-lg p-2.5 outline-none"></div>
                        </div>
                        <div class="pt-6 border-t flex justify-end gap-3">
                            <button type="button" onclick="changeView('dashboard')" class="px-6 py-2.5 rounded-lg border font-bold">Cancelar</button>
                            <button type="submit" class="bg-brand-lime text-white px-8 py-2.5 rounded-lg font-bold shadow-md">Salvar</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- VIEW: DOCS (O MOTOR DO CARREGAMENTO) -->
            <div id="view-docs" class="hidden fade-in max-w-6xl mx-auto">
                 <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <div>
                        <button onclick="changeView('dashboard')" class="text-gray-400 hover:text-gray-600 text-xs font-bold flex items-center gap-1 mb-2 uppercase"><i data-lucide="arrow-left" class="w-3 h-3"></i> Voltar</button>
                        <h2 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                            <i data-lucide="folder-check" class="text-brand-dark"></i> 
                            <span id="docs-emp-name">Documentação</span>
                        </h2>
                    </div>
                    <div class="bg-white px-4 py-2 rounded-lg border">
                        <span class="text-xs text-gray-500 uppercase font-bold mr-2">Progresso:</span>
                        <span id="docs-progress" class="text-lg font-bold text-brand-dark">0/0</span>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="docs-grid"></div>
            </div>

            <!-- OUTRAS VIEWS (ADMIN) -->
            <div id="view-projects" class="hidden fade-in max-w-5xl mx-auto">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-2xl font-bold">Meus Projetos</h2>
                    <button onclick="openProjectModal()" class="bg-brand-dark text-white px-5 py-2.5 rounded-lg font-bold shadow-md">+ Novo Projeto</button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid"></div>
            </div>

            <div id="view-users" class="hidden fade-in max-w-5xl mx-auto">
                <h2 class="text-2xl font-bold mb-8">Gestão de Acessos</h2>
                <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-gray-50 text-gray-500 text-xs uppercase font-bold">
                            <tr><th class="px-6 py-4">Usuário</th><th class="px-6 py-4">Perfil</th><th class="px-6 py-4">Projetos</th><th class="px-6 py-4 text-right">Ações</th></tr>
                        </thead>
                        <tbody id="users-table-body" class="divide-y text-sm"></tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>

    <!-- MODAIS -->
    <div id="loading-overlay"><div class="bg-white p-6 rounded-xl flex flex-col items-center gap-3"><div class="w-10 h-10 border-4 border-t-brand-dark rounded-full animate-spin"></div><p class="text-gray-700 font-bold">Processando...</p></div></div>
    
    <div id="feedback-modal" class="modal-overlay">
        <div class="modal-box">
            <h3 class="text-lg font-bold mb-2 text-brand-dark">Observações do Documento</h3>
            <p id="feedback-subtitle" class="text-xs text-gray-500 mb-4 uppercase border-b pb-2"></p>
            <textarea id="feedback-input" class="w-full border rounded p-3 text-sm outline-none" rows="4" placeholder="Escreva o motivo da reprovação ou notas..."></textarea>
            <div class="flex justify-end gap-2 mt-4">
                <button onclick="closeFeedbackModal()" class="px-4 py-2 rounded border font-bold text-xs">Fechar</button>
                <button id="btn-save-feedback" class="bg-brand-dark text-white px-4 py-2 rounded font-bold text-xs">Salvar</button>
            </div>
        </div>
    </div>

    <div id="audit-modal" class="modal-overlay">
        <div class="modal-box">
            <h3 class="text-lg font-bold mb-4">Histórico do Documento</h3>
            <div id="audit-content" class="space-y-4 text-sm"></div>
            <div class="flex justify-end mt-6"><button onclick="document.getElementById('audit-modal').classList.remove('active')" class="px-4 py-2 rounded bg-gray-200 font-bold text-xs">Fechar</button></div>
        </div>
    </div>

    <!-- MODAL GENÉRICO E DE CONFIRMAÇÃO (NOVO) -->
    <div id="modal-overlay" class="modal-overlay">
        <div class="modal-box">
            <h3 id="modal-title" class="text-lg font-bold mb-3 text-gray-800"></h3>
            <div id="modal-content" class="text-gray-600 text-sm mb-6"></div>
            <div id="modal-actions" class="flex justify-end gap-2"></div>
        </div>
    </div>

    <div id="gallery-overlay">
        <button onclick="closeGallery()" class="absolute top-4 right-4 text-white p-2"><i data-lucide="x" class="w-8 h-8"></i></button>
        <div id="gallery-content"></div>
    </div>

    <div id="project-modal" class="modal-overlay">
        <div class="modal-box">
            <h3 class="text-lg font-bold mb-4">Novo Projeto</h3>
            <form id="project-form" class="space-y-4">
                <div><label class="text-xs font-bold uppercase">Nome *</label><input type="text" id="proj-name" required class="w-full border p-2 rounded"></div>
                <div class="flex justify-end gap-2 pt-4">
                    <button type="button" onclick="closeProjectModal()" class="px-4 py-2 border rounded text-sm font-bold">Cancelar</button>
                    <button type="submit" class="bg-brand-dark text-white px-4 py-2 rounded text-sm font-bold">Criar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL DE EDIÇÃO DE ACESSOS (ADICIONADO) -->
    <div id="user-edit-modal" class="modal-overlay">
        <div class="modal-box">
            <h3 class="text-lg font-bold mb-2 text-brand-dark">Acessos do Usuário</h3>
            <p id="user-edit-email" class="text-sm font-bold text-gray-700 mb-4"></p>
            <input type="hidden" id="user-edit-id">
            <p class="text-xs font-bold text-gray-500 uppercase mb-2">Projetos Disponíveis:</p>
            <div id="user-projects-list" class="space-y-2 max-h-60 overflow-y-auto mb-4 border border-gray-100 rounded p-2"></div>
            <div class="flex justify-end gap-2">
                <button onclick="document.getElementById('user-edit-modal').classList.remove('active')" class="px-4 py-2 rounded border border-gray-300 text-gray-600 font-bold text-sm">Cancelar</button>
                <button onclick="saveUserPermissions()" class="bg-brand-lime text-white px-4 py-2 rounded font-bold text-sm">Salvar Permissões</button>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.6.0/firebase-app.js";
        import { getAuth, signInWithEmailAndPassword, createUserWithEmailAndPassword, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/12.6.0/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot, doc, updateDoc, deleteDoc, getDocs, query, where, getDoc } from "https://www.gstatic.com/firebasejs/12.6.0/firebase-firestore.js";
        import { getStorage, ref, uploadBytes, getDownloadURL } from "https://www.gstatic.com/firebasejs/12.6.0/firebase-storage.js";

        // CONFIGURAÇÃO DO PROJETO (REUTILIZADA)
        const firebaseConfig = { apiKey: "AIzaSyDO97QHrE5mtr_TZZyEa5K92g_nxXODSDI", authDomain: "gestaocolaboradorr.firebaseapp.com", projectId: "gestaocolaboradorr", storageBucket: "gestaocolaboradorr.firebasestorage.app", messagingSenderId: "1049282434044", appId: "1:1049282434044:web:deb180ec5c36501fde9879" };
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const storage = getStorage(app);

        let employees = [], projects = [], currentProject = null;
        let isAdmin = false, currentUser = null, currentUserData = null;
        let currentEmployeeId = null;
        let employeesUnsubscribe = null; // Variável para controlar o listener

        const stdDocTypes = [
            { id: 'ficha_registro', label: 'Ficha de registro' }, { id: 'rg_cpf', label: 'RG e CPF' }, 
