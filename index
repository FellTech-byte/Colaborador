            if(!isAdmin) { customAlert("Apenas administradores podem excluir."); return; }
            const confirm = await customConfirm("Tem certeza que deseja excluir este colaborador? Essa ação é irreversível.");
            if(confirm) {
                toggleLoading(true);
                try {
                    await deleteDoc(doc(db, "funcionarios", id));
                } catch(e) {
                    console.error(e);
                    customAlert("Erro ao excluir colaborador.");
                } finally {
                    toggleLoading(false);
                }
            }
